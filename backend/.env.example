# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to Git!

# PostgreSQL connection string (used by FastAPI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/rotafive

# PostgreSQL password (used by Docker Compose to init the DB container)
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT Secret Key (use a long random string, e.g. openssl rand -hex 32)
JWT_SECRET_KEY=changeme-replace-with-a-very-long-random-string

# JWT token expiration in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
